# ─────────────────────────────────────────────────────────────────────────────
# IPQC Webapp — environment variable template
# Copy to .env and fill in values for your server before starting the app.
# The systemd service reads this file via EnvironmentFile=/opt/ipqc/qc/webapp/.env
# ─────────────────────────────────────────────────────────────────────────────

# ── App paths ─────────────────────────────────────────────────────────────────

# Absolute path to the webapp working directory (the directory containing app.py).
# Set automatically when using the systemd WorkingDirectory directive.
IPQC_WORKDIR=/Users/vivianschu/repos/ipqc/qc/webapp

# ── MHCflurry ─────────────────────────────────────────────────────────────────
# MHCflurry is pip-installable into the main virtualenv; no extra env vars needed
# beyond downloading model weights once:
#   mhcflurry-downloads fetch    (~500 MB, stored in ~/.local/share/mhcflurry/)
#
# Override the model cache directory if needed:
# MHCFLURRY_DATA_PATH=/opt/ipqc/mhcflurry_data

# ── NetMHCpan ─────────────────────────────────────────────────────────────────
# NetMHCpan is a licensed binary from DTU Health Tech (academic use).
# Install it manually, then either:
#   (a) add its directory to PATH in this file, or
#   (b) the app calls shutil.which("netMHCpan"), so ensure the binary name matches.

PATH=/Users/vivianschu/repos/ipqc/qc/webapp/tools/netMHCpan-4.2:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# ── BigMHC ────────────────────────────────────────────────────────────────────
# BigMHC runs in its own Python 3.9 conda environment.
# BIGMHC_DIR must point to the cloned repo root (the dir containing src/predict.py).
BIGMHC_DIR=/opt/bigmhc
BIGMHC_PYTHON=/opt/conda/envs/bigmhc/bin/python

# ── TransHLA ──────────────────────────────────────────────────────────────────
# TransHLA runs in its own Python 3.9 conda environment.
# TRANSHLA_DIR must point to the cloned repo root (the dir containing TransHLA_I.py).
TRANSHLA_DIR=/opt/TransHLA
TRANSHLA_PYTHON=/opt/conda/envs/transhla/bin/python